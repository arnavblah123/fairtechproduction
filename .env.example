# Postgres connection string used by the running app.
# On Neon: the POOLED string (-pooler host) + "&pgbouncer=true&connect_timeout=15"
DATABASE_URL="postgresql://user:password@localhost:5432/fairtech"
# Connection used for migrations/seed during build.
# On Neon: the DIRECT string (host without -pooler). Locally: same as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/fairtech"
# Random secret for signing session cookies (use `openssl rand -hex 32`)
SESSION_SECRET=""
# Shared secret the attendance vendor must send in the X-Webhook-Secret header (empty = check disabled)
ATTENDANCE_WEBHOOK_SECRET=""

# Google Calendar sync (free — see README "Google Calendar" for the 5-minute setup).
# Leave all three empty to disable sync; the per-job "Add to Google Calendar"
# button works regardless.
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Paste the private_key value from the service account JSON key (\n escapes are fine)
GOOGLE_PRIVATE_KEY=""
# The target calendar's ID (Calendar settings → "Integrate calendar"), e.g. abc123@group.calendar.google.com
GOOGLE_CALENDAR_ID=""
